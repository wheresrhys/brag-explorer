ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Either a Vercel Blob URL or a local file path (e.g. ./work-history.md)
WORK_HISTORY_BLOB_URL=https://your-blob-url.public.blob.vercel-storage.com/work-history.md
# Required for private Vercel Blob stores; auto-set by Vercel when you link a store to a project
# BLOB_READ_WRITE_TOKEN=your_blob_read_write_token
NEXT_PUBLIC_OWNER_NAME=Rhys
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
# Optional: maximum questions per visitor per day (omit for unlimited)
# NEXT_PUBLIC_DAILY_QUESTION_LIMIT=5
